<Window x:Class="KluboviSrbije.Windows.ViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
        xmlns:fa5 ="http://schemas.fontawesome.com/icons/"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="600"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <!-- Akcent boja -->
        <SolidColorBrush x:Key="AccentColor" Color="#0078D7"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!--<notifications:NotificationArea
        x:Name="WindowNotificationArea"
        Panel.ZIndex="100"
        MaxItems="3"
        Position="TopCenter"
        Margin="0,10,0,0"/> -->

        <Canvas Width="600" Height="600">
            <Path
        Name="UIPath"
        Fill="White"
        Stroke="DarkGray"
        StrokeThickness="2">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure IsClosed="True" StartPoint="300,0">
                            <LineSegment Point="450,40" />
                            <LineSegment Point="559,150" />
                            <LineSegment Point="600,300" />
                            <LineSegment Point="559,450" />
                            <LineSegment Point="450,559" />
                            <LineSegment Point="300,600" />
                            <LineSegment Point="150,559" />
                            <LineSegment Point="40,450" />
                            <LineSegment Point="0,300" />
                            <LineSegment Point="40,150" />
                            <LineSegment Point="150,40" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <Button BorderThickness="0" Background="Transparent" Width="25" Height="25" Margin="430,40,120,0" x:Name="ExitButton" Click="ExitButton_Click" HorizontalAlignment="Right" VerticalAlignment="Top" >
                <fa5:SvgAwesome 
                    Icon="Regular_TimesCircle"
                    Foreground="Black"/>
            </Button>

            <Grid Canvas.Left="0" Canvas.Top="0"  Width="600" Height="600" Panel.ZIndex="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0.5*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Name="NameLabel" FontWeight="Bold" FontSize="30" Margin="0,70,0,0">

                </Label>

                <RichTextBox Grid.Row="1" Grid.Column="0" Margin="50, 0, 0, 0" x:Name="RichTextBoxView" IsReadOnly="True"></RichTextBox>

                <Border x:Name="ImageBorder" Grid.Row="1" Grid.Column="1" BorderThickness="1" BorderBrush="Black" Height="80" Width="80" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,20,0,0">
                    <Image x:Name="ImgSrc" Stretch="Fill"></Image>
                </Border>

                <Label Grid.Row="1" Grid.Column="1" Content="" x:Name="SelectedImageLabel" Margin="0,100,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">

                </Label>
                
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Kapacitet stadiona:" Margin="50, 10, 0, 0" FontWeight="Bold"/>
                    <TextBox x:Name="capacityTextBox" FontWeight="Bold" Background="LightGray" Text="" Width="200" Height="20" VerticalAlignment="Top" Margin="5, 10, 0, 0" IsReadOnly="True"/>
                </StackPanel>

                <Button Style="{StaticResource ActionButton}" Background="#FFCCCCCC" Foreground="#333333" Content="Nazad" Click="BackButton_Click" Grid.Column="0" Grid.Row="2" Margin="185,0,0,0"/>

            </Grid>
        </Canvas>
    </Grid>
</Window>