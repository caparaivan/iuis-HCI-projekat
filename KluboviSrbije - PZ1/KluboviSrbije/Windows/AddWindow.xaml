<Window x:Class="KluboviSrbije.Windows.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:notifications="clr-namespace:Notification.Wpf.Controls;assembly=Notification.Wpf"
        xmlns:fa5 ="http://schemas.fontawesome.com/icons/"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D7"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Canvas Width="600" Height="600">
            <Path
        Name="UIPath"
        Fill="White"
        Stroke="DarkGray"
        StrokeThickness="2">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure IsClosed="True" StartPoint="300,0">
                            <LineSegment Point="450,40" />
                            <LineSegment Point="559,150" />
                            <LineSegment Point="600,300" />
                            <LineSegment Point="559,450" />
                            <LineSegment Point="450,559" />
                            <LineSegment Point="300,600" />
                            <LineSegment Point="150,559" />
                            <LineSegment Point="40,450" />
                            <LineSegment Point="0,300" />
                            <LineSegment Point="40,150" />
                            <LineSegment Point="150,40" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <Button BorderThickness="0" Background="Transparent" Width="25" Height="25" Margin="430,40,120,0" x:Name="ExitButton" Click="ExitButton_Click" HorizontalAlignment="Right" VerticalAlignment="Top" >
                <fa5:SvgAwesome 
                    Icon="Regular_TimesCircle"
                    Foreground="Black"/>
            </Button>

            <TextBlock x:Name="TitleTextBlock" 
                FontSize="30" 
                FontWeight="Bold" 
                Canvas.Top="40"
                Canvas.Left="180"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="1">
                <Run Text="Dodavanje" Foreground="Red"/><Run Text=" Kluba" Foreground="#0078D7"/>
            </TextBlock>
            
            <Grid Canvas.Left="100" Canvas.Top="100"  Width="500" Height="430" Panel.ZIndex="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0.6*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Naziv:" FontWeight="Bold" FontSize="10" Margin="0,1,0,0"></TextBlock>
                
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <TextBox x:Name="NameTextBox" Margin="30,0,0,0"  Height="17" GotFocus="txbName_GotFocus" LostFocus="txbName_LostFocus" VerticalAlignment="Top"/>
                    <TextBox Text="" Foreground="Red" x:Name="NameErrorLabel" BorderThickness="0" IsReadOnly="True"/>
                </StackPanel>
                    
                <ToolBar Grid.Row="1" Grid.Column="0" Width="250" HorizontalAlignment="Left">
                    <ComboBox x:Name="FontFamilyComboBox" Width="150" SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                    <ComboBox x:Name="FontSizeComboBox" Width="60" Margin="5,0,0,0" SelectionChanged="FontSizeComboBox_SelectionChanged"/>
                </ToolBar>

                <ToolBar Grid.Row="2" Grid.Column="0" Margin="0,0,0,0">
                    <ToggleButton Name="BoldToggleButton" Command="EditingCommands.ToggleBold" ToolTip="Bold" Height="25" Width="25" >
                        <fa5:SvgAwesome
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Black"
                            Icon="Solid_Bold" />
                    </ToggleButton>

                    <ToggleButton Name="ItalicToggleButton" Command="EditingCommands.ToggleItalic" ToolTip="Italic" Width="25"  Height="25">
                        <fa5:SvgAwesome
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Black"
                            Icon="Solid_Italic" />
                    </ToggleButton>

                    <ToggleButton Name="UnderlineToggleButton" Command="EditingCommands.ToggleUnderline" ToolTip="Underline" Width="25" Height="25">
                        <fa5:SvgAwesome
                            Width="15"
                            Height="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Black"
                            Icon="Solid_Underline" />
                    </ToggleButton>

                    <ComboBox
                        Name="ColorComboBox"
                        Width="200"
                        Height="25"
                        IsTextSearchCaseSensitive="False"
                        IsTextSearchEnabled="False"
                        SelectionChanged="ColorComboBox_SelectionChanged"
                        >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="15" Height="15" Margin="0,0,0,0">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding}"/>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <TextBlock Text="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>

                    </ComboBox>

                </ToolBar>
                
                <RichTextBox Name="EditorRichTextBox" Grid.Row="3" Grid.RowSpan="2" HorizontalAlignment="Left" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto" SelectionChanged="EditorRichTextBox_SelectionChanged" TextChanged="EditorRichTextBox_TextChanged" GotKeyboardFocus="EditorRichTextBox_GotFocus" LostKeyboardFocus="EditorRichTextBox_LostFocus">
                    <FlowDocument>
                        <Paragraph Foreground="Gray">
                            <Run Text="Unesite opis kluba..."/>
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>

                <TextBlock Grid.Row="4" VerticalAlignment="Bottom"
                           x:Name="RichTextBoxError"
                           Foreground="Red"
                           Text="">
                </TextBlock>

                <TextBlock 
                        Grid.Column="1"
                        Grid.Row="3"
                        Text="Grb:"
                        Margin="25,0,0,10"
                        VerticalAlignment="Center"
                        FontWeight="Bold"/>

                <StackPanel Orientation="Vertical" Grid.Row="3" Grid.Column="1">


                    <Border x:Name="BorderForImage"
                        Width="80" Height="80"
                        Background="White"
                        BorderBrush="DarkGray"
                        BorderThickness="1"
                        Margin="0,10,0,0">
                        <Image x:Name="ImagePreview"
                        Stretch="Fill"/>
                    </Border>
                    <Label x:Name="SelectedImageNameLabel" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="3" Margin="0,0,0,0" Content="">
                    </Label>
                </StackPanel>

                <Button Style="{StaticResource ActionButton}"
                            Grid.Row="4" Grid.Column="1"
                            VerticalAlignment="Top"
                            Margin="6,5,0,0"
                            Content="Dodaj sliku"
                            Click="AddImgBtn_Click"/>
                
                <StackPanel Orientation="Vertical" Grid.Row="5">
                    <StatusBar Height="20" VerticalAlignment="Top">
                        <StatusBarItem>
                            <TextBlock x:Name="StatusBarText" FontWeight="Bold" FontSize="10" Text="Broj reci: " TextAlignment="Center"/>
                        </StatusBarItem>
                    </StatusBar>

                    <TextBlock Text="Kapacitet stadiona:" FontSize="8" FontWeight="Bold">
                        
                    </TextBlock>

                    <TextBox x:Name="capacityTxb" GotFocus="Capacity_GotFocus" LostFocus="Capacity_LostFocus" BorderBrush="DarkGray" BorderThickness="1" Margin="0, 0, 0, 0">
                        
                    </TextBox>

                    <TextBox x:Name="capacityError" Foreground="Red" Text="" BorderThickness="0" IsReadOnly="True">
                        
                    </TextBox>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button Style="{StaticResource ActionButton}"
                                Content="Sacuvaj"
                                Click="SaveButton_Click"/>
                            <Button Style="{StaticResource ActionButton}"
                                Background="#FFCCCCCC"
                                Foreground="#333333"
                                Content="Nazad"
                                Click="CancelBtn_Click"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
            
            
        </Canvas>
    </Grid>
</Window>