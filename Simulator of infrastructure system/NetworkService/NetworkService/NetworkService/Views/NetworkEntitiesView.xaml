<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5 ="http://schemas.fontawesome.com/icons/"
             xmlns:local="clr-namespace:NetworkService.Views"
             mc:Ignorable="d" 
             Width="700" Height="700"
             >
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <StackPanel 
                    Orientation="Vertical" 
                    Margin="120 20 0 30">

                    <StackPanel 
                        Orientation="Horizontal" >
                        <ComboBox
                            x:Name="comboBoxEntityType" 
                            ItemsSource="{Binding ComboBoxItems}" 
                            SelectedItem="{Binding CurrentEntityType.Type, Mode=TwoWay}" 
                            Width="120"
                            Cursor="Hand"
                            ToolTip="Choose entity type"
                            Height="30"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Margin="0,0,28,0"/>
                        <Button
                            x:Name="AddEntityBTN"
                            Margin="0 0 0 0"
                            Cursor="Hand"
                            ToolTip="Add new entity"
                            Content="Add entity"
                            Width="80" 
                            Height="30"
                            Foreground="#fff"
                            Background="Gray"
                            BorderBrush="Black"
                            HorizontalAlignment="Left"
                            Command="{Binding AddEntityCommand}"
                            ></Button>
                    </StackPanel>
                    <TextBlock  
                        Foreground="Red" 
                        Text="{Binding ErrorMSg}"
                        ></TextBlock>
                </StackPanel>
                <StackPanel Orientation="Vertical" Margin="202 20 0 30">
                    <Button
                        x:Name="DeleteEntityBTN"
                        Margin="0 0 0 0"
                        Content="Delete entity"
                        Cursor="Hand"
                        ToolTip="Delete entity"
                        Width="80" 
                        Height="30" 
                        HorizontalAlignment="Right"
                        Command="{Binding DeleteEntityCommand}"
                        Foreground="Black"
                        Background="Gray"
                        BorderBrush="Black"
                        ></Button>
                </StackPanel>
            </StackPanel>
            <StackPanel 
                Orientation="Vertical" 
                Margin="120 0 0 0">
                <DataGrid 
                    x:Name="dataGridEntities" 
                    ItemsSource="{Binding EntitiesToShow}" 
                    SelectedItem="{Binding SelectedEntity}" 
                    Background="Gray"
                    BorderBrush="#000"
                    BorderThickness="1"
                    Height="300" 
                    Width="510"
                    HorizontalAlignment="Left" 
                    Margin="0,5,0,0" 
                    RowHeight="20" 
                    IsReadOnly="True" 
                    SelectionMode="Single" 
                    AutoGenerateColumns="False" 
                    CanUserAddRows="False" 
                    CanUserReorderColumns="False" 
                    CanUserResizeColumns="False" 
                    VerticalScrollBarVisibility="Hidden" 
                    ScrollViewer.CanContentScroll="False">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Height" Value="20"/>
                            <Setter Property="BorderBrush" Value="#000" />
                            <Setter Property="BorderThickness" Value="1" />
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Grid>
                                            <ContentPresenter 
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="Black" />
                            <Setter Property="BorderBrush" Value="DimGray" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="LightBlue" />
                                    <Setter Property="Foreground" Value="Black" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="Black" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="LightBlue" />
                                    <Setter Property="Foreground" Value="Black" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type.Type}" Width="*"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
            <StackPanel 
                Orientation="Horizontal" 
                Margin="120 20 0 0">
                <ComboBox
                    x:Name="comboBoxSearchTypes" 
                    ItemsSource="{Binding ComboBoxItems}" 
                    SelectedItem="{Binding SelectedFilterType, Mode=TwoWay}" 
                    Width="120"
                    Cursor="Hand"
                    ToolTip="Choose entity type"
                    Height="30"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="0,0,28,0"/>
                <StackPanel 
                    Margin="0 0 5 0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <RadioButton 
                        Foreground="#949BA4"
                        GroupName="OperatorFilter"
                        IsChecked="{Binding IsGreaterThanSelected, Mode=TwoWay}"
                        x:Name="nameRB"
                        Cursor="Hand"
                        Margin="0 0 10 0"
                        >&gt;</RadioButton>
                    <RadioButton
                        GroupName="OperatorFilter"
                        Foreground="#949BA4" 
                        IsChecked="{Binding IsLessThanSelected, Mode=TwoWay}"
                        x:Name="typeRB"
                        Cursor="Hand"
                        >&lt;</RadioButton>
                    <RadioButton 
                        Foreground="#949BA4"
                        GroupName="OperatorFilter"
                        IsChecked="{Binding IsEqualSelected, Mode=TwoWay}" 
                        x:Name="nameRBeq"
                        Cursor="Hand"
                        Margin="0 0 10 0"
                        >=</RadioButton>
                </StackPanel>
                <TextBox Width="135" Text="{Binding IdFilterText, UpdateSourceTrigger=PropertyChanged}">
                </TextBox>
                
                <Button 
                    Command="{Binding FilterEntityCommand}" 
                    Height="30"
                    Cursor="Hand"
                    ToolTip="Filter table"
                    Width="50" 
                    HorizontalAlignment="Left" 
                    Margin="10 0 0 0" 
                    Content="Filter"
                    Foreground="#fff"
                    Background="Gray"
                    BorderBrush="Black"
                    ></Button>
                <Button 
                    Command="{Binding RefreshEntityCommand}" 
                    Height="30" 
                    Width="50"
                    Cursor="Hand"
                    Content="Refresh"
                    ToolTip="Refresh table"
                    HorizontalAlignment="Center" 
                    Foreground="#fff"
                    Background="Gray"
                    BorderBrush="Black"
                    Margin="10 0 0 0" >
                </Button>
            </StackPanel>
            <Border Background="#1E1F22"
            CornerRadius="5"
            Padding="8"
            Margin="0,0,0,0"
            Height="170">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding TerminalOutput}"
                           Foreground="White"
                           FontFamily="Consolas"
                           TextWrapping="Wrap"/>
                    </ScrollViewer>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox Text="{Binding TerminalInput, UpdateSourceTrigger=PropertyChanged}"
                         Width="500"
                         FontFamily="Consolas"
                         Background="#2B2D31"
                         Foreground="White"
                         BorderThickness="1"
                         BorderBrush="#555">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding RunTerminalCommand}" CommandParameter="{Binding Text, ElementName=terminalInput}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="Run"
                        Command="{Binding RunTerminalCommand}"
                        Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
        </StackPanel>         
    </Grid>
</UserControl>
