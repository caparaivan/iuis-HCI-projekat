<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             mc:Ignorable="d" 
             Width="700" Height="700"
             FontFamily="Trebuchet MS">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel 
                Orientation="Horizontal" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Margin="130 20 70 20">
                <TextBlock 
                    Foreground="#949BA4" 
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold" 
                    Text="Entity:" 
                    Margin="0 0 15 0 "
                    ></TextBlock>
                <ComboBox 
                    Cursor="Hand"
                    ToolTip="Choose entity"
                    Width="120" 
                    Height="30"
                    ItemsSource="{Binding ComboBoxItems}"
                    SelectedItem="{Binding SelectedEntity, Mode=TwoWay}"
                    Margin="0 0 15 0 "
                    DisplayMemberPath="Name"
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    ></ComboBox>
                <Button 
                    Cursor="Hand"
                    ToolTip="Show entity"
                    Background="#1E1F22"
                    Foreground="Gray" 
                    FontWeight="Bold"
                    BorderBrush="#000" 
                    Height="30" 
                    Width="100" 
                    Content="Show"
                    Command="{Binding ShowCommand}"
                    ></Button>
            </StackPanel>
            <Border BorderBrush="#000" BorderThickness="0" Margin="130 0 70 0" Height="485">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>

                    <ItemsControl Grid.Row="0" ItemsSource="{Binding CircleMarkers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Canvas Width="80" Height="425">
                                    <Grid Height="50" Width="50" Canvas.Top="{Binding CmYPosition}" HorizontalAlignment="Center">
                                        <Ellipse Fill="{Binding CmColor}" Height="50" Width="50"/>
                                        <TextBlock Text="{Binding CmValue, StringFormat={}{0:F2}}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CircleMarkers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="80" Orientation="Vertical" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CmDate}" Foreground="White" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding CmTime}" Foreground="White" TextAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
